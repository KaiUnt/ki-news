# OpenAI
OPENAI_API_KEY=sk-...

# Supabase – REST Client (für spätere direkte API-Nutzung)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<anon-or-service-role-key>

# SQLAlchemy – direkte PostgreSQL-Verbindung zu Supabase
# Direktverbindung (benötigt IPv4-Add-on bei Supabase):
#   DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# Oder über Transaction Pooler (empfohlen für Serverless/VPS):
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# App
APP_ENV=development
APP_SECRET_KEY=change-me-in-production

# Reddit API
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=KI-News-Bot/1.0

# Schutz der Run-Endpunkte (nur aktiv wenn APP_ENV=production)
# Beliebiges sicheres Passwort setzen – wird als HTTP Basic Auth Passwort verlangt
RUN_PASSWORD=
